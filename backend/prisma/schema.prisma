// ============ CONFIGURACAO DA EMPRESA (UMA POR TENANT) ============

model ConfiguracaoEmpresa {
  id           String    @id @default(uuid())
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  inscEstadual String?
  telefone     String?
  email        String?
  endereco     String?
  numero       String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  logotipo     String?
  observacoes  String?
  tipoCaixa    TipoCaixa @default(INDEPENDENTE)

  // ============ MERCADO PAGO POINT ============
  // Credenciais da maquininha fisica (1 device por tenant — para multiplos
  // devices basta replicar este modelo no futuro). mpAccessTokenEnc guarda o
  // token PROD do MP cifrado com AES-256-GCM (lib/cripto.js). NUNCA expor
  // valor decifrado em GETs do frontend — sempre retornar mascarado.
  // mpWebhookSecret e gerado pelo backend no momento de salvar a config e
  // serve para validar autenticidade dos webhooks (header x-signature do MP
  // alem do tenant resolvido pelo external_reference).
  mpAccessTokenEnc String?
  mpDeviceId       String?
  mpUserIdMp       String?
  mpWebhookSecret  String?
  mpAtivo          Boolean @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String  @unique
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("configuracao_empresa")
}

// ============ CONFIGURACAO IMPRESSORA NAO-FISCAL ============
// Singleton por tenant. Define largura/layout do cupom termico e quais
// documentos imprimem (venda, orcamento, sangria/suprimento, fechamento,
// recibo financeiro). Lido pelo helper src/lib/impressora.js no frontend
// antes de cada chamada a window.print(). Hoje so impacta o caminho
// "browser print" (window.print() + @media print). Espaco reservado pra
// futura integracao ESC/POS via agente local ou IP de impressora de rede.

enum LarguraImpressao {
  MM_58
  MM_80
  A4
}

model ConfiguracaoImpressora {
  id    String  @id @default(uuid())
  ativo Boolean @default(true)

  // Layout fisico
  largura   LarguraImpressao @default(MM_80)
  fonteBase Int              @default(12)
  margemMm  Int              @default(4)

  // Conteudo opcional do cupom (sobre/sob os dados da empresa)
  cabecalhoExtra  String?
  rodapeExtra     String?
  mostrarLogo     Boolean @default(true)
  mostrarCnpj     Boolean @default(true)
  mostrarVendedor Boolean @default(true)
  mostrarCliente  Boolean @default(true)

  // Comportamento de impressao
  viasVenda           Int     @default(1)
  cortarLinhasFinal   Int     @default(4)
  abrirGavetaDinheiro Boolean @default(false)
  imprimirAutomatico  Boolean @default(true)

  // Quais documentos imprimem
  imprimirVenda      Boolean @default(true)
  imprimirOrcamento  Boolean @default(true)
  imprimirSangria    Boolean @default(true)
  imprimirSuprimento Boolean @default(true)
  imprimirFechamento Boolean @default(true)
  imprimirReciboFin  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String  @unique
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("configuracao_impressora")
}

model MovimentacaoCaixa {
  id             String                @id @default(uuid())
  tipo           TipoMovimentacaoCaixa
  valor          Decimal               @db.Decimal(10, 2)
  formaPagamento FormaPagamento        @default(DINHEIRO)
  descricao      String
  saldoAntes     Decimal               @db.Decimal(10, 2)
  saldoDepois    Decimal               @db.Decimal(10, 2)
  createdAt      DateTime              @default(now())

  caixaId String
  caixa   Caixa  @relation(fields: [caixaId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  vendaId        String?
  venda          Venda?        @relation(fields: [vendaId], references: [id])
  contaPagarId   String?
  contaPagar     ContaPagar?   @relation(fields: [contaPagarId], references: [id])
  contaReceberId String?
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([caixaId, createdAt])
  @@index([tenantId])
  @@map("movimentacoes_caixa")
}

// ============ ORCAMENTOS / ORDENS DE SERVICO ============

model Orcamento {
  id          String          @id @default(uuid())
  // Numero sequencial POR TENANT (ETAPA 8). Ver lib/proximoNumero.js.
  numero      Int
  tipo        TipoOrcamento   @default(ORCAMENTO)
  status      StatusOrcamento @default(RASCUNHO)
  tabelaPreco TabelaPreco     @default(AV)

  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id])
  descricaoCliente String?
  contato          String?
  telefone         String?

  via Int @default(1)

  observacoes         String?
  imprimirObservacoes Boolean @default(true)
  rodape              String?

  mostrarValorMetro Boolean @default(false)
  imprimirValores   Boolean @default(true)

  valorProdutos Decimal @default(0) @db.Decimal(10, 2)
  valorServicos Decimal @default(0) @db.Decimal(10, 2)
  deslocamento  Decimal @default(0) @db.Decimal(10, 2)
  desconto      Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @default(0) @db.Decimal(10, 2)

  formaCondicaoPagamento String?

  dataAprovacao      DateTime?
  dataEntrega        DateTime?
  dataRejeicao       DateTime?
  motivoRejeicao     String?
  dataCancelamento   DateTime?
  motivoCancelamento String?

  userId        String
  user          User    @relation("OrcamentoCriador", fields: [userId], references: [id])
  responsavelId String?
  responsavel   User?   @relation("OrcamentoResponsavel", fields: [responsavelId], references: [id])

  vendaId String? @unique
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens ItemOrcamento[]

  @@unique([tenantId, numero])
  @@index([clienteId])
  @@index([status])
  @@index([tipo, status])
  @@index([tenantId])
  @@map("orcamentos")
}

model ItemOrcamento {
  id String @id @default(uuid())

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  descricao String

  quantidade Decimal @db.Decimal(10, 3)

  valorUnitario Decimal @db.Decimal(10, 4)

  largura     Decimal? @db.Decimal(10, 3)
  altura      Decimal? @db.Decimal(10, 3)
  totalEm     Decimal  @default(0) @db.Decimal(10, 4)
  acertoTotal Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  formato     String?
  vias        String?
  cores       String?
  complemento String?

  ordem Int @default(0)

  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([orcamentoId, ordem])
  @@index([tenantId])
  @@map("itens_orcamento")
}

