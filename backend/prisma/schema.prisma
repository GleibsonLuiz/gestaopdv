}

model Anexo {
  id             String   @id @default(uuid())
  nomeOriginal   String
  nomeArmazenado String
  mimeType       String
  tamanho        Int
  url            String
  createdAt      DateTime @default(now())

  contaPagarId String?
  contaPagar   ContaPagar? @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)

  contaReceberId String?
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([contaPagarId])
  @@index([contaReceberId])
