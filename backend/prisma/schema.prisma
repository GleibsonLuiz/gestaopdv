// Schema do banco de dados - Gestao + PDV (Multi-tenant)
// Documentacao: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  ADMIN
  GERENTE
  VENDEDOR
}

enum StatusVenda {
  PENDENTE
  CONCLUIDA
  CANCELADA
  EM_EDICAO
}

enum StatusConta {
  PENDENTE
  PAGA
  ATRASADA
  CANCELADA
}

enum FormaPagamento {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  BOLETO
  CREDIARIO
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE
}

enum TipoRecorrencia {
  NENHUMA
  PARCELADA
  RECORRENTE
}

enum TipoItem {
  PRODUTO
  SERVICO
}

enum StatusCaixa {
  ABERTO
  FECHADO
}

// Politica de uso do caixa por instalacao do sistema.
//
//   INDEPENDENTE - cada usuario opera o proprio caixa; vendas exigem que o
//                  usuario logado tenha um caixa aberto pessoal.
//   COMPARTILHADO - existe no maximo UM caixa aberto por turno na empresa;
//                  qualquer vendedor registra vendas nele.
enum TipoCaixa {
  INDEPENDENTE
  COMPARTILHADO
}

enum TipoMovimentacaoCaixa {
  ABERTURA
  VENDA
  ESTORNO_VENDA
  SANGRIA
  SUPRIMENTO
  PAGAR_CONTA
  RECEBER_CONTA
  ESTORNO_PAGAR_CONTA
  ESTORNO_RECEBER_CONTA
  FECHAMENTO
}

enum TipoOrcamento {
  ORCAMENTO
  ORDEM_SERVICO
}

enum TipoInteracao {
  LIGACAO
  WHATSAPP
  VISITA
  EMAIL
  REUNIAO
  ANOTACAO
}

enum TipoMovimentacaoPontos {
  GANHO
  RESGATE
  AJUSTE
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusTarefa {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum StatusOrcamento {
  RASCUNHO
  AGUARDANDO_APROVACAO
  APROVADO
  REJEITADO
  ENTREGUE
  CANCELADO
}

enum TabelaPreco {
  AV
  PZ
  AT
}

enum TipoComissao {
  PORCENTAGEM
  VALOR_FIXO
}

enum BaseComissao {
  VALOR_BRUTO
  LUCRO_LIQUIDO
}

enum EtapaFunil {
  LEAD
  QUALIFICADO
  PROPOSTA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum TipoTemplate {
  WHATSAPP
  EMAIL
  SMS
}

enum TipoRegraAutomacao {
  CLIENTE_INATIVO
  ORCAMENTO_PARADO
  POS_VENDA_FOLLOWUP
}

enum StatusClienteFunil {
  LEAD
  CLIENTE_ATIVO
  CLIENTE_INATIVO
  PERDIDO
}

// ============ MULTI-TENANT ============
//
// Empresa = tenant. Cada registro de negocio (cliente, produto, venda, etc)
// tem tenantId apontando para a empresa-dona. Isolamento e garantido pelo
// middleware backend (req.tenantId injetado no JWT) + clausula WHERE em
// toda query.
//
// FASE 1 desta migration: tenantId e NULLABLE em todas as tabelas para
// permitir o backfill dos registros existentes. FASE 2 (proxima migration)
// torna NOT NULL apos o backfill.
model Empresa {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?  @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations (uma por modelo com tenantId)
  formasPagamentoCustom  FormaPagamentoCustom[]
  users                  User[]
  configuracoesComissao  ConfiguracaoComissao[]
  clientes               Cliente[]
  fornecedores           Fornecedor[]
  categorias             Categoria[]
  produtos               Produto[]
  vendas                 Venda[]
  itensVenda             ItemVenda[]
  compras                Compra[]
  itensCompra            ItemCompra[]
  movimentacoesEstoque   MovimentacaoEstoque[]
  contasPagar            ContaPagar[]
  contasReceber          ContaReceber[]
  anexos                 Anexo[]
  caixas                 Caixa[]
  configuracaoEmpresa    ConfiguracaoEmpresa?
  movimentacoesCaixa     MovimentacaoCaixa[]
  orcamentos             Orcamento[]
  itensOrcamento         ItemOrcamento[]
  configuracaoFidelidade ConfiguracaoFidelidade?
  pontosCliente          PontosCliente[]
  movimentacoesPontos    MovimentacaoPontos[]
  tarefas                Tarefa[]
  interacoes             Interacao[]
  oportunidades          Oportunidade[]
  tags                   Tag[]
  clienteTags            ClienteTag[]
  contatos               Contato[]
  pesquisasNps           PesquisaNps[]
  templatesMensagem      TemplateMensagem[]
  regrasAutomacao        RegraAutomacao[]
  logsAutomacao          LogAutomacao[]
  historicoOportunidades HistoricoOportunidade[]
  logsAuditoria          LogAuditoria[]

  @@map("empresas")
}

// ============ FORMAS DE PAGAMENTO CUSTOM ============

model FormaPagamentoCustom {
  id                 String         @id @default(uuid())
  nome               String
  icone              String?
  baseFormaPagamento FormaPagamento
  ativo              Boolean        @default(true)
  ordem              Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("formas_pagamento_custom")
}

// ============ USUARIOS ============

model User {
  id         String   @id @default(uuid())
  nome       String
  email      String
  senha      String
  role       Role     @default(VENDEDOR)
  ativo      Boolean  @default(true)
  permissoes String[] @default([])
  // superAdmin = desenvolvedor/dono do sistema (cross-tenant). Diferente do
  // role ADMIN que e por tenant. Apenas super-admin pode acessar /admin-master,
  // ver lista de TODAS as empresas e criar novos tenants. Default false: a
  // grande maioria dos users sao admins/gerentes/vendedores de uma empresa.
  superAdmin Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendas                   Venda[]
  movimentacoes            MovimentacaoEstoque[]
  caixas                   Caixa[]
  movimentacoesCaixa       MovimentacaoCaixa[]
  orcamentos               Orcamento[]             @relation("OrcamentoCriador")
  orcamentosResponsavel    Orcamento[]             @relation("OrcamentoResponsavel")
  configuracaoComissao     ConfiguracaoComissao?
  interacoes               Interacao[]
  tarefasCriadas           Tarefa[]                @relation("TarefaCriador")
  tarefasResponsavel       Tarefa[]                @relation("TarefaResponsavel")
  movimentacoesPontos      MovimentacaoPontos[]
  oportunidadesCriadas     Oportunidade[]          @relation("OportunidadeCriador")
  oportunidadesResponsavel Oportunidade[]          @relation("OportunidadeResponsavel")
  historicoOportunidades   HistoricoOportunidade[]
  regrasAutomacao          RegraAutomacao[]        @relation("RegraAutomacaoResponsavel")
  logsAuditoria            LogAuditoria[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ============ COMISSAO ============

model ConfiguracaoComissao {
  id           String       @id @default(uuid())
  tipo         TipoComissao @default(PORCENTAGEM)
  base         BaseComissao @default(VALOR_BRUTO)
  valor        Decimal      @db.Decimal(10, 2)
  metaMensal   Decimal      @default(0) @db.Decimal(10, 2)
  bonusPorMeta Decimal      @default(0) @db.Decimal(5, 2)
  ativo        Boolean      @default(true)
  observacoes  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("configuracoes_comissao")
}

// ============ CADASTROS ============

model Cliente {
  id             String             @id @default(uuid())
  nome           String
  cpfCnpj        String?
  email          String?
  telefone       String?
  endereco       String?
  cidade         String?
  estado         String?
  cep            String?
  observacoes    String?
  ativo          Boolean            @default(true)
  origem         String?
  statusFunil    StatusClienteFunil @default(LEAD)
  dataNascimento DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendas              Venda[]
  contasReceber       ContaReceber[]
  orcamentos          Orcamento[]
  interacoes          Interacao[]
  tarefas             Tarefa[]
  pontosCliente       PontosCliente?
  movimentacoesPontos MovimentacaoPontos[]
  oportunidades       Oportunidade[]
  tags                ClienteTag[]
  contatos            Contato[]
  pesquisasNps        PesquisaNps[]

  @@unique([tenantId, cpfCnpj])
  @@index([tenantId])
  @@map("clientes")
}

model Fornecedor {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?
  email     String?
  telefone  String?
  endereco  String?
  cidade    String?
  estado    String?
  cep       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  produtos    Produto[]
  compras     Compra[]
  contasPagar ContaPagar[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@map("fornecedores")
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String
  createdAt DateTime @default(now())

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  produtos Produto[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("categorias")
}

// ============ PRODUTOS / ESTOQUE ============

model Produto {
  id            String   @id @default(uuid())
  codigo        String
  codigoBarras  String?
  referencia    String?
  nome          String
  descricao     String?
  imagem        String?
  tipoItem      TipoItem @default(PRODUTO)
  precoVenda    Decimal  @db.Decimal(10, 2)
  precoCusto    Decimal? @db.Decimal(10, 2)
  estoque       Int      @default(0)
  estoqueMinimo Int      @default(0)
  unidade       String   @default("UN")
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itensVenda     ItemVenda[]
  itensCompra    ItemCompra[]
  itensOrcamento ItemOrcamento[]
  movimentacoes  MovimentacaoEstoque[]

  @@unique([tenantId, codigo])
  @@unique([tenantId, codigoBarras])
  @@index([tenantId])
  @@map("produtos")
}

// ============ VENDAS (PDV) ============

model Venda {
  id             String         @id @default(uuid())
  // Numero sequencial POR TENANT. Calculado no controller via MAX+1
  // com retry em caso de race condition (ver lib/proximoNumero.js).
  numero         Int
  total          Decimal        @db.Decimal(10, 2)
  desconto       Decimal        @default(0) @db.Decimal(10, 2)
  formaPagamento FormaPagamento
  status         StatusVenda    @default(CONCLUIDA)
  observacoes    String?
  createdAt      DateTime       @default(now())

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  caixaId String?
  caixa   Caixa?  @relation(fields: [caixaId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itens               ItemVenda[]
  movimentacoesCaixa  MovimentacaoCaixa[]
  orcamento           Orcamento?
  contasReceber       ContaReceber[]
  movimentacoesPontos MovimentacaoPontos[]
  oportunidade        Oportunidade?
  pesquisaNps         PesquisaNps?

  @@unique([tenantId, numero])
  @@index([caixaId])
  @@index([tenantId])
  @@map("vendas")
}

model ItemVenda {
  id            String  @id @default(uuid())
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  vendaId String
  venda   Venda  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("itens_venda")
}

// ============ COMPRAS ============

model Compra {
  id                 String    @id @default(uuid())
  // Numero sequencial POR TENANT (ETAPA 8). Ver lib/proximoNumero.js.
  numero             Int
  total              Decimal   @db.Decimal(10, 2)
  observacoes        String?
  cancelada          Boolean   @default(false)
  canceladaEm        DateTime?
  motivoCancelamento String?
  createdAt          DateTime  @default(now())

  fornecedorId String
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itens       ItemCompra[]
  contasPagar ContaPagar[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@map("compras")
}

model ItemCompra {
  id            String  @id @default(uuid())
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  compraId String
  compra   Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("itens_compra")
}

// ============ FINANCEIRO ============

model MovimentacaoEstoque {
  id            String           @id @default(uuid())
  tipo          TipoMovimentacao
  quantidade    Int
  estoqueAntes  Int
  estoqueDepois Int
  motivo        String?
  createdAt     DateTime         @default(now())

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([produtoId, createdAt])
  @@index([tenantId])
  @@map("movimentacoes_estoque")
}

model ContaPagar {
  id                 String          @id @default(uuid())
  descricao          String
  valor              Decimal         @db.Decimal(10, 2)
  valorBruto         Decimal         @default(0) @db.Decimal(10, 2)
  juros              Decimal         @default(0) @db.Decimal(10, 2)
  multa              Decimal         @default(0) @db.Decimal(10, 2)
  desconto           Decimal         @default(0) @db.Decimal(10, 2)
  vencimento         DateTime
  pagamento          DateTime?
  status             StatusConta     @default(PENDENTE)
  observacoes        String?
  tipoRecorrencia    TipoRecorrencia @default(NENHUMA)
  grupoRecorrenciaId String?
  parcelaAtual       Int?
  parcelaTotal       Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])

  compraId String?
  compra   Compra? @relation(fields: [compraId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  anexos             Anexo[]
  movimentacoesCaixa MovimentacaoCaixa[]

  @@index([grupoRecorrenciaId])
  @@index([compraId])
  @@index([tenantId])
  @@map("contas_pagar")
}

model ContaReceber {
  id                 String          @id @default(uuid())
  descricao          String
  valor              Decimal         @db.Decimal(10, 2)
  valorBruto         Decimal         @default(0) @db.Decimal(10, 2)
  juros              Decimal         @default(0) @db.Decimal(10, 2)
  multa              Decimal         @default(0) @db.Decimal(10, 2)
  desconto           Decimal         @default(0) @db.Decimal(10, 2)
  vencimento         DateTime
  recebimento        DateTime?
  status             StatusConta     @default(PENDENTE)
  observacoes        String?
  tipoRecorrencia    TipoRecorrencia @default(NENHUMA)
  grupoRecorrenciaId String?
  parcelaAtual       Int?
  parcelaTotal       Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  vendaId String?
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  anexos             Anexo[]
  movimentacoesCaixa MovimentacaoCaixa[]

  @@index([grupoRecorrenciaId])
  @@index([vendaId])
  @@index([tenantId])
  @@map("contas_receber")
}

model Anexo {
  id             String   @id @default(uuid())
  nomeOriginal   String
  nomeArmazenado String
  mimeType       String
  tamanho        Int
  url            String
  createdAt      DateTime @default(now())

  contaPagarId String?
  contaPagar   ContaPagar? @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)

  contaReceberId String?
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([contaPagarId])
  @@index([contaReceberId])
  @@index([tenantId])
  @@map("anexos")
}

// ============ CAIXA ============

model Caixa {
  id                    String      @id @default(uuid())
  // Numero sequencial POR TENANT (ETAPA 8). Ver lib/proximoNumero.js.
  numero                Int
  status                StatusCaixa @default(ABERTO)
  saldoInicial          Decimal     @db.Decimal(10, 2)
  saldoFinalContado     Decimal?    @db.Decimal(10, 2)
  saldoFinalEsperado    Decimal?    @db.Decimal(10, 2)
  trocoProximoDia       Decimal?    @db.Decimal(10, 2)
  diferenca             Decimal?    @db.Decimal(10, 2)
  observacoesAbertura   String?
  observacoesFechamento String?
  abertoEm              DateTime    @default(now())
  fechadoEm             DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendas        Venda[]
  movimentacoes MovimentacaoCaixa[]

  @@unique([tenantId, numero])
  @@index([userId, status])
  @@index([abertoEm])
  @@index([tenantId])
  @@map("caixas")
}

// ============ CONFIGURACAO DA EMPRESA (UMA POR TENANT) ============

model ConfiguracaoEmpresa {
  id           String    @id @default(uuid())
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  inscEstadual String?
  telefone     String?
  email        String?
  endereco     String?
  numero       String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  logotipo     String?
  observacoes  String?
  tipoCaixa    TipoCaixa @default(INDEPENDENTE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String  @unique
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("configuracao_empresa")
}

model MovimentacaoCaixa {
  id             String                @id @default(uuid())
  tipo           TipoMovimentacaoCaixa
  valor          Decimal               @db.Decimal(10, 2)
  formaPagamento FormaPagamento        @default(DINHEIRO)
  descricao      String
  saldoAntes     Decimal               @db.Decimal(10, 2)
  saldoDepois    Decimal               @db.Decimal(10, 2)
  createdAt      DateTime              @default(now())

  caixaId String
  caixa   Caixa  @relation(fields: [caixaId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  vendaId        String?
  venda          Venda?        @relation(fields: [vendaId], references: [id])
  contaPagarId   String?
  contaPagar     ContaPagar?   @relation(fields: [contaPagarId], references: [id])
  contaReceberId String?
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([caixaId, createdAt])
  @@index([tenantId])
  @@map("movimentacoes_caixa")
}

// ============ ORCAMENTOS / ORDENS DE SERVICO ============

model Orcamento {
  id          String          @id @default(uuid())
  // Numero sequencial POR TENANT (ETAPA 8). Ver lib/proximoNumero.js.
  numero      Int
  tipo        TipoOrcamento   @default(ORCAMENTO)
  status      StatusOrcamento @default(RASCUNHO)
  tabelaPreco TabelaPreco     @default(AV)

  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id])
  descricaoCliente String?
  contato          String?
  telefone         String?

  via Int @default(1)

  observacoes         String?
  imprimirObservacoes Boolean @default(true)
  rodape              String?

  mostrarValorMetro Boolean @default(false)
  imprimirValores   Boolean @default(true)

  valorProdutos Decimal @default(0) @db.Decimal(10, 2)
  valorServicos Decimal @default(0) @db.Decimal(10, 2)
  deslocamento  Decimal @default(0) @db.Decimal(10, 2)
  desconto      Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @default(0) @db.Decimal(10, 2)

  formaCondicaoPagamento String?

  dataAprovacao      DateTime?
  dataEntrega        DateTime?
  dataRejeicao       DateTime?
  motivoRejeicao     String?
  dataCancelamento   DateTime?
  motivoCancelamento String?

  userId        String
  user          User    @relation("OrcamentoCriador", fields: [userId], references: [id])
  responsavelId String?
  responsavel   User?   @relation("OrcamentoResponsavel", fields: [responsavelId], references: [id])

  vendaId String? @unique
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens ItemOrcamento[]

  @@unique([tenantId, numero])
  @@index([clienteId])
  @@index([status])
  @@index([tipo, status])
  @@index([tenantId])
  @@map("orcamentos")
}

model ItemOrcamento {
  id String @id @default(uuid())

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  descricao String

  quantidade Decimal @db.Decimal(10, 3)

  valorUnitario Decimal @db.Decimal(10, 4)

  largura     Decimal? @db.Decimal(10, 3)
  altura      Decimal? @db.Decimal(10, 3)
  totalEm     Decimal  @default(0) @db.Decimal(10, 4)
  acertoTotal Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  formato     String?
  vias        String?
  cores       String?
  complemento String?

  ordem Int @default(0)

  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([orcamentoId, ordem])
  @@index([tenantId])
  @@map("itens_orcamento")
}

// ============ FIDELIDADE / PONTOS ============

model ConfiguracaoFidelidade {
  id               String   @id @default(uuid())
  ativo            Boolean  @default(true)
  reaisPorPonto    Decimal  @default(1) @db.Decimal(10, 2)
  pontosParaUmReal Int      @default(100)
  minimoResgate    Int      @default(100)
  maximoDescPct    Decimal  @default(50) @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenantId String  @unique
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("configuracao_fidelidade")
}

model PontosCliente {
  id             String   @id @default(uuid())
  saldo          Int      @default(0)
  totalGanho     Int      @default(0)
  totalResgatado Int      @default(0)
  updatedAt      DateTime @updatedAt

  clienteId String  @unique
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("pontos_cliente")
}

model MovimentacaoPontos {
  id        String                 @id @default(uuid())
  tipo      TipoMovimentacaoPontos
  pontos    Int
  descricao String?
  createdAt DateTime               @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  vendaId String?
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId, createdAt(sort: Desc)])
  @@index([vendaId])
  @@index([tenantId])
  @@map("movimentacoes_pontos")
}

// ============ CRM — TAREFAS E FOLLOW-UPS ============

model Tarefa {
  id          String           @id @default(uuid())
  titulo      String
  descricao   String?
  prazo       DateTime?
  prioridade  PrioridadeTarefa @default(MEDIA)
  status      StatusTarefa     @default(ABERTA)
  concluidaEm DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   User?   @relation("TarefaResponsavel", fields: [responsavelId], references: [id])

  criadoPorId String
  criadoPor   User   @relation("TarefaCriador", fields: [criadoPorId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, prazo])
  @@index([responsavelId, status])
  @@index([clienteId])
  @@index([tenantId])
  @@map("tarefas")
}

// ============ CRM — INTERACOES ============

model Interacao {
  id        String        @id @default(uuid())
  tipo      TipoInteracao @default(ANOTACAO)
  descricao String
  data      DateTime      @default(now())
  createdAt DateTime      @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId, data(sort: Desc)])
  @@index([tenantId])
  @@map("interacoes")
}

// ============ CRM — FUNIL DE VENDAS (OPORTUNIDADES) ============

model Oportunidade {
  id        String     @id @default(uuid())
  // Numero sequencial POR TENANT (ETAPA 8). Ver lib/proximoNumero.js.
  numero    Int
  titulo    String
  descricao String?
  etapa     EtapaFunil @default(LEAD)

  probabilidade Int @default(0)

  valorEstimado Decimal? @db.Decimal(10, 2)

  dataFechamentoPrevista DateTime?

  origem String?

  dataGanho   DateTime?
  dataPerdida DateTime?
  motivoPerda String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   User?   @relation("OportunidadeResponsavel", fields: [responsavelId], references: [id])

  criadoPorId String
  criadoPor   User   @relation("OportunidadeCriador", fields: [criadoPorId], references: [id])

  vendaId String? @unique
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historico HistoricoOportunidade[]

  @@unique([tenantId, numero])
  @@index([etapa])
  @@index([responsavelId, etapa])
  @@index([clienteId])
  @@index([tenantId])
  @@map("oportunidades")
}

// ============ CRM — TAGS / ETIQUETAS DE CLIENTE ============

model Tag {
  id        String   @id @default(uuid())
  nome      String
  cor       String   @default("#4f8ef7")
  createdAt DateTime @default(now())

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientes ClienteTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("tags")
}

model ClienteTag {
  clienteId String
  tagId     String
  createdAt DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([clienteId, tagId])
  @@index([tagId])
  @@index([tenantId])
  @@map("cliente_tags")
}

// ============ CRM — CONTATOS DO CLIENTE (B2B) ============

model Contato {
  id          String   @id @default(uuid())
  nome        String
  cargo       String?
  email       String?
  telefone    String?
  principal   Boolean  @default(false)
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([tenantId])
  @@map("contatos")
}

// ============ CRM — PESQUISA NPS POS-VENDA ============

model PesquisaNps {
  id           String    @id @default(uuid())
  token        String    @unique
  nota         Int?
  comentario   String?
  respondidaEm DateTime?
  createdAt    DateTime  @default(now())

  vendaId String @unique
  venda   Venda  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId, respondidaEm])
  @@index([createdAt])
  @@index([tenantId])
  @@map("pesquisas_nps")
}

// ============ CRM — TEMPLATES DE MENSAGEM ============

model TemplateMensagem {
  id        String       @id @default(uuid())
  nome      String
  tipo      TipoTemplate
  assunto   String?
  corpo     String       @db.Text
  ativo     Boolean      @default(true)
  ordem     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tipo, ativo])
  @@index([tenantId])
  @@map("templates_mensagem")
}

// ============ CRM — REGRAS DE AUTOMACAO ============

model RegraAutomacao {
  id    String             @id @default(uuid())
  nome  String
  tipo  TipoRegraAutomacao
  ativo Boolean            @default(true)

  diasGatilho Int?
  valorMinimo Decimal? @db.Decimal(10, 2)

  tituloTarefa     String
  descricaoTarefa  String?
  prioridadeTarefa PrioridadeTarefa @default(MEDIA)
  prazoEmDias      Int              @default(7)

  responsavelId String?
  responsavel   User?   @relation("RegraAutomacaoResponsavel", fields: [responsavelId], references: [id])

  ultimaExecucao DateTime?
  totalDisparos  Int       @default(0)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs LogAutomacao[]

  @@index([tipo, ativo])
  @@index([tenantId])
  @@map("regras_automacao")
}

model LogAutomacao {
  id      String         @id @default(uuid())
  regraId String
  regra   RegraAutomacao @relation(fields: [regraId], references: [id], onDelete: Cascade)

  clienteId   String?
  orcamentoId String?
  vendaId     String?

  tarefaId  String?
  resultado String  @default("CRIADA")

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([regraId, createdAt(sort: Desc)])
  @@index([clienteId, regraId])
  @@index([orcamentoId, regraId])
  @@index([vendaId, regraId])
  @@index([tenantId])
  @@map("logs_automacao")
}

// ============ HISTORICO DE OPORTUNIDADES ============

model HistoricoOportunidade {
  id            String      @id @default(uuid())
  etapaAnterior EtapaFunil?
  etapaNova     EtapaFunil
  observacao    String?
  createdAt     DateTime    @default(now())

  oportunidadeId String
  oportunidade   Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId, createdAt])
  @@index([tenantId])
  @@map("historico_oportunidades")
}

// ============ AUDITORIA ============

model LogAuditoria {
  id          String   @id @default(uuid())
  acao        String
  modulo      String
  entidadeId  String?
  metodo      String?
  rota        String?
  statusCode  Int?
  sucesso     Boolean  @default(true)
  ip          String?
  userAgent   String?
  dadosAntes  Json?
  dadosDepois Json?
  diff        Json?
  duracaoMs   Int?
  mensagem    String?
  createdAt   DateTime @default(now())

  usuarioId    String?
  usuario      User?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  usuarioNome  String?
  usuarioEmail String?

  // tenantId fica NULLABLE (unico caso em todo o schema): login com email
  // inexistente nao tem como saber o tenant antes de validar. Outros 34
  // modelos sao NOT NULL desde a migration da ETAPA 6.
  tenantId String?
  tenant   Empresa? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([usuarioId, createdAt])
  @@index([modulo, createdAt])
  @@index([acao, createdAt])
  @@index([createdAt])
  @@index([tenantId])
  @@map("logs_auditoria")
}
