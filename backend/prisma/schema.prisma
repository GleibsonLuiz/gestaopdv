  @@index([clienteId])
  @@index([tenantId])
  @@map("oportunidades")
}

// ============ CRM — TAGS / ETIQUETAS DE CLIENTE ============

model Tag {
  id        String   @id @default(uuid())
  nome      String
  cor       String   @default("#4f8ef7")
  createdAt DateTime @default(now())

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientes ClienteTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("tags")
}

model ClienteTag {
  clienteId String
  tagId     String
  createdAt DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([clienteId, tagId])
  @@index([tagId])
  @@index([tenantId])
  @@map("cliente_tags")
}

// ============ CRM — CONTATOS DO CLIENTE (B2B) ============

model Contato {
  id          String   @id @default(uuid())
  nome        String
  cargo       String?
  email       String?
  telefone    String?
  principal   Boolean  @default(false)
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([tenantId])
  @@map("contatos")
}

// ============ CRM — PESQUISA NPS POS-VENDA ============

model PesquisaNps {
  id           String    @id @default(uuid())
  token        String    @unique
  nota         Int?
  comentario   String?
  respondidaEm DateTime?
  createdAt    DateTime  @default(now())

  vendaId String @unique
  venda   Venda  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clienteId, respondidaEm])
  @@index([createdAt])
  @@index([tenantId])
  @@map("pesquisas_nps")
}

// ============ CRM — TEMPLATES DE MENSAGEM ============

model TemplateMensagem {
  id        String       @id @default(uuid())
  nome      String
  tipo      TipoTemplate
  assunto   String?
  corpo     String       @db.Text
  ativo     Boolean      @default(true)
  ordem     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tipo, ativo])
  @@index([tenantId])
  @@map("templates_mensagem")
}

// ============ CRM — REGRAS DE AUTOMACAO ============

model RegraAutomacao {
  id    String             @id @default(uuid())
  nome  String
  tipo  TipoRegraAutomacao
  ativo Boolean            @default(true)

  diasGatilho Int?
  valorMinimo Decimal? @db.Decimal(10, 2)

  tituloTarefa     String
  descricaoTarefa  String?
  prioridadeTarefa PrioridadeTarefa @default(MEDIA)
  prazoEmDias      Int              @default(7)

  responsavelId String?
  responsavel   User?   @relation("RegraAutomacaoResponsavel", fields: [responsavelId], references: [id])

  ultimaExecucao DateTime?
  totalDisparos  Int       @default(0)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs LogAutomacao[]

  @@index([tipo, ativo])
  @@index([tenantId])
  @@map("regras_automacao")
}

model LogAutomacao {
  id      String         @id @default(uuid())
  regraId String
  regra   RegraAutomacao @relation(fields: [regraId], references: [id], onDelete: Cascade)

  clienteId   String?
  orcamentoId String?
  vendaId     String?

  tarefaId  String?
  resultado String  @default("CRIADA")

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([regraId, createdAt(sort: Desc)])
  @@index([clienteId, regraId])
  @@index([orcamentoId, regraId])
  @@index([vendaId, regraId])
  @@index([tenantId])
  @@map("logs_automacao")
}

// ============ HISTORICO DE OPORTUNIDADES ============

model HistoricoOportunidade {
  id            String      @id @default(uuid())
  etapaAnterior EtapaFunil?
  etapaNova     EtapaFunil
  observacao    String?
  createdAt     DateTime    @default(now())

  oportunidadeId String
  oportunidade   Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId, createdAt])
  @@index([tenantId])
  @@map("historico_oportunidades")
}

// ============ AUDITORIA ============

model LogAuditoria {
  id          String   @id @default(uuid())
  acao        String
  modulo      String
  entidadeId  String?
  metodo      String?
  rota        String?
  statusCode  Int?
  sucesso     Boolean  @default(true)
  ip          String?
  userAgent   String?
  dadosAntes  Json?
  dadosDepois Json?
  diff        Json?
  duracaoMs   Int?
  mensagem    String?
  createdAt   DateTime @default(now())

  usuarioId    String?
  usuario      User?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  usuarioNome  String?
  usuarioEmail String?

  // tenantId fica NULLABLE (unico caso em todo o schema): login com email
  // inexistente nao tem como saber o tenant antes de validar. Outros 34
  // modelos sao NOT NULL desde a migration da ETAPA 6.
  tenantId String?
  tenant   Empresa? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([usuarioId, createdAt])
  @@index([modulo, createdAt])
  @@index([acao, createdAt])
  @@index([createdAt])
  @@index([tenantId])
  @@map("logs_auditoria")
}

// ============ ETAPA 12 — NOTIFICACOES BROADCAST ============
//
// Mensagens enviadas pelo super-admin para TODOS os tenants (ex: aviso de
// manutencao, anuncio de feature). Nao tem tenantId — sao globais. Cada
// user marca individualmente como "lida" via NotificacaoLida (junction).
//
// O frontend mostra como banner no topo do app principal, com botao "X"
// que chama POST /notificacoes/:id/marcar-lida.
model Notificacao {
  id        String          @id @default(uuid())
  titulo    String
  mensagem  String          @db.Text
  tipo      TipoNotificacao @default(INFO)
  // ativa=false esconde dos users mesmo que nao tenham marcado como lida
  ativa     Boolean         @default(true)
  // Quando preenchido, notificacao some automaticamente apos a data
  expiraEm  DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  criadoPorId String
  criadoPor   User   @relation("NotificacaoCriador", fields: [criadoPorId], references: [id])

  // destinoTenantId=null -> broadcast (todos os tenants). Setado -> mensagem
  // direcionada so pros users daquele tenant. Cascade pra remover mensagens
  // se a empresa for deletada.
  destinoTenantId String?
  destinoTenant   Empresa? @relation(fields: [destinoTenantId], references: [id], onDelete: Cascade)

  lidas NotificacaoLida[]

  @@index([ativa, createdAt(sort: Desc)])
  @@index([destinoTenantId])
  @@map("notificacoes")
}

// ============ INTENCAO DE PAGAMENTO MERCADO PAGO (API POINT) ============
//
// Cada vez que o operador clica em "Cobrar na maquininha", o PDV cria uma
// IntencaoPagamentoMP com o payload completo da venda (itens, cliente,
// pagamentos, observacoes) serializado em `vendaPayloadJson`. O backend
// envia uma payment-intent para a maquininha via API Point e guarda o
// `intentId` retornado.
//
// O PDV ja NAO cria a Venda real nesse momento — ela so e criada quando o
// webhook do MP confirma APPROVED (entao executamos vendaController.criar
// com o payload salvo, dentro do tenantStorage correto). Se REJECTED ou
// CANCELED, a venda nunca existe — sem necessidade de estorno.
//
// O frontend faz polling em GET /pagamentos-mp/status/:id ate ver um status
// final (APPROVED/REJECTED/CANCELED/ERROR), entao limpa o carrinho.

model IntencaoPagamentoMP {
  id        String           @id @default(uuid())
  status    StatusIntencaoMP @default(PENDING)
  tipo      TipoPagamentoMP
  // Valor enviado para a maquininha em CENTAVOS (formato exigido pelo MP).
  // Tipo Int evita float drift quando o webhook reconcilia.
  valor     Int
  // Identificador da intent no Mercado Pago. Preenchido apos a chamada
  // POST /devices/{id}/payment-intents. Null se a chamada falhar antes
  // de chegar no MP (status = ERROR).
  intentId  String?  @unique
  deviceId  String
  // Payload completo da venda (clienteId, itens[], pagamentos[], desconto,
  // observacoes, pontosResgatar, gerarContaReceber). Re-executado pelo
  // webhook handler via vendaController.criar quando aprovado.
  vendaPayloadJson Json
  // Quando aprovado, aponta para a Venda gerada. Permite o GET de status
  // devolver o numero da venda criada para o PDV exibir.
  vendaId    String?  @unique
  // Mensagem livre: motivo de recusa do MP, erro de comunicacao, ou nota
  // do cancelamento manual. Exibida no modal de status.
  detalhe   String?
  // Snapshot do payload bruto da notificacao do MP (ultimo polling do
  // payment). Util para debug e auditoria.
  rawWebhook Json?

  // PIX: codigo EMV (copia e cola) e imagem base64 do QR Code dinamico.
  // Populados apenas quando tipo=PIX e a chamada a /v1/payments retornou
  // os dados de point_of_interaction. Null para CREDIT/DEBIT.
  qrCode       String?
  qrCodeBase64 String?

  createdAt   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  caixaId String?
  caixa   Caixa?  @relation(fields: [caixaId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("intencoes_pagamento_mp")
}

model NotificacaoLida {
  notificacaoId String
  notificacao   Notificacao @relation(fields: [notificacaoId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lidaEm DateTime @default(now())

  @@id([notificacaoId, userId])
  @@index([userId])
  @@map("notificacoes_lidas")
}
