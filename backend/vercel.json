{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "public",
  "regions": ["gru1"],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/cron/automacoes",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/cron/assinaturas",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/cron/fiscal-pendentes",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/cron/fiscal-certificados",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/cron/fiscal-dfe",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/contabilidade-fechamento",
      "schedule": "0 8 1 * *"
    }
  ]
}
