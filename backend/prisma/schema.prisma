// Schema do banco de dados - Gestao + PDV (Multi-tenant)
// Documentacao: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  ADMIN
  GERENTE
  VENDEDOR
}

enum StatusVenda {
  PENDENTE
  CONCLUIDA
  CANCELADA
  EM_EDICAO
}

// Ciclo de vida de uma intencao de cobranca enviada para a maquininha do
// Mercado Pago (API Point). PENDING = enviada e aguardando, APPROVED =
// MP confirmou via webhook (gera Venda real), REJECTED = recusada pelo
// emissor, CANCELED = cancelada pelo operador ou expirou no device,
// ERROR = falha ao comunicar com a API antes de chegar no device.
enum StatusIntencaoMP {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  ERROR
}

// Tipo de pagamento que o operador escolheu antes de enviar para a maquininha.
// Mapeia para o body { payment.type, payment.installments } do Point API.
enum TipoPagamentoMP {
  CREDIT
  DEBIT
  PIX
}

enum StatusConta {
  PENDENTE
  PAGA
  ATRASADA
  CANCELADA
}

enum FormaPagamento {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  BOLETO
  CREDIARIO
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE
}

enum TipoRecorrencia {
  NENHUMA
  PARCELADA
  RECORRENTE
}

enum TipoItem {
  PRODUTO
  SERVICO
}

enum StatusCaixa {
  ABERTO
  FECHADO
}

// Politica de uso do caixa por instalacao do sistema.
//
//   INDEPENDENTE - cada usuario opera o proprio caixa; vendas exigem que o
//                  usuario logado tenha um caixa aberto pessoal.
//   COMPARTILHADO - existe no maximo UM caixa aberto por turno na empresa;
//                  qualquer vendedor registra vendas nele.
enum TipoCaixa {
  INDEPENDENTE
  COMPARTILHADO
}

enum TipoMovimentacaoCaixa {
  ABERTURA
  VENDA
  ESTORNO_VENDA
  SANGRIA
  SUPRIMENTO
  PAGAR_CONTA
  RECEBER_CONTA
  ESTORNO_PAGAR_CONTA
  ESTORNO_RECEBER_CONTA
  FECHAMENTO
}

enum TipoOrcamento {
  ORCAMENTO
  ORDEM_SERVICO
}

enum TipoInteracao {
  LIGACAO
  WHATSAPP
  VISITA
  EMAIL
  REUNIAO
  ANOTACAO
}

enum TipoMovimentacaoPontos {
  GANHO
  RESGATE
  AJUSTE
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusTarefa {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum StatusOrcamento {
  RASCUNHO
  AGUARDANDO_APROVACAO
  APROVADO
  REJEITADO
  ENTREGUE
  CANCELADO
}

enum TabelaPreco {
  AV
  PZ
  AT
}

enum TipoComissao {
  PORCENTAGEM
  VALOR_FIXO
}

enum BaseComissao {
  VALOR_BRUTO
  LUCRO_LIQUIDO
}

enum EtapaFunil {
  LEAD
  QUALIFICADO
  PROPOSTA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum TipoTemplate {
  WHATSAPP
  EMAIL
  SMS
}

enum TipoRegraAutomacao {
  CLIENTE_INATIVO
  ORCAMENTO_PARADO
  POS_VENDA_FOLLOWUP
}

enum StatusClienteFunil {
  LEAD
  CLIENTE_ATIVO
  CLIENTE_INATIVO
  PERDIDO
}

// Inventario com contagem cega. Fluxo:
//   ABERTO     - gestor abriu, snapshot do estoque logico congelado por item,
//                operador digita contagens (sem ver o sistema)
//   CONCLUIDO  - gestor consolidou: estoques ajustados, movimentacoes AJUSTE
//                geradas, contagens nao podem mais ser alteradas
//   CANCELADO  - gestor descartou; nenhuma mudanca em estoque
enum StatusInventario {
  ABERTO
  CONCLUIDO
  CANCELADO
}

// ETAPA 12: planos comerciais. Cada um pode ter limites (decididos no
// codigo, nao no banco — facil ajustar sem migration).
//   TRIAL      - 14 dias, todas features liberadas
//   FREE       - permanente, limitado (ex: max 50 clientes, 100 produtos)
//   STARTER    - pago, limite expandido
//   PRO        - pago, sem limites
//   ENTERPRISE - customizado
enum Plano {
  TRIAL
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ETAPA 12: tipo da notificacao define cor e icone no banner do usuario.
enum TipoNotificacao {
  INFO
  AVISO
  MANUTENCAO
  NOVIDADE
}

// ETAPA 14: Origem da mercadoria (Tabela A da NT 2011/004 SEFAZ).
// Vai no campo <orig> do XML da NF-e/NFC-e. Obrigatorio em toda nota
// fiscal eletronica. O nome do enum maquia o codigo numerico, mas a
// posicao na lista (NACIONAL = 0, ESTRANGEIRA_IMP_DIRETA = 1, ...)
// preserva o mapeamento direto para o XML.
enum OrigemMercadoria {
  NACIONAL // 0
  ESTRANGEIRA_IMP_DIRETA // 1
  ESTRANGEIRA_ADQUIRIDA_BR // 2
  NACIONAL_IMP_SUP_40 // 3 (Conteudo Importacao > 40% e <= 70%)
  NACIONAL_PROC_BAS // 4 (processos produtivos basicos)
  NACIONAL_IMP_INF_40 // 5 (CI <= 40%)
  ESTRANGEIRA_IMP_SEM_SIM // 6 (importacao direta, sem similar nacional)
  ESTRANGEIRA_ADQ_SEM_SIM // 7 (adquirida no BR, sem similar nacional)
  NACIONAL_IMP_SUP_70 // 8 (CI > 70%)
}

// ETAPA 14: Regime tributario do item. Define se vamos popular cstIcms
// (regime normal) OU csosnIcms (Simples Nacional) no XML da NF-e.
// Guardado por produto (nao so por empresa) porque permite cenarios
// mistos — empresa Simples revendendo produto com ST embutido, etc.
enum RegimeTributario {
  SIMPLES_NACIONAL // CRT=1 — usa CSOSN
  SIMPLES_EXCESSO_SUBLIMITE // CRT=2 — usa CSOSN
  REGIME_NORMAL // CRT=3 — usa CST do ICMS
}

// ============ MULTI-TENANT ============
//
// Empresa = tenant. Cada registro de negocio (cliente, produto, venda, etc)
// tem tenantId apontando para a empresa-dona. Isolamento e garantido pelo
// middleware backend (req.tenantId injetado no JWT) + clausula WHERE em
// toda query.
//
// FASE 1 desta migration: tenantId e NULLABLE em todas as tabelas para
// permitir o backfill dos registros existentes. FASE 2 (proxima migration)
// torna NOT NULL apos o backfill.
model Empresa {
  id               String    @id @default(uuid())
  nome             String
  cnpj             String?   @unique
  ativo            Boolean   @default(true)
  // ETAPA 11: motivo + data de suspensao. Quando ativo=false, motivoSuspensao
  // explica pro user (mostrado na tela de login bloqueado). suspensaEm e
  // setado pelo super-admin no momento do PATCH /admin-master/empresas/:id/status.
  motivoSuspensao  String?
  suspensaEm       DateTime?
  // ETAPA 12: plano comercial. TRIAL e o default (14 dias gratis). expiraEm
  // controla validade do plano atual — quando vence, login retorna 403 com
  // motivo "Plano expirado em XX/XX/XXXX". Super-admin renova via tela
  // /admin-master.
  plano            Plano     @default(TRIAL)
  expiraEm         DateTime?
  observacoesPlano String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Back-relations (uma por modelo com tenantId)
  formasPagamentoCustom  FormaPagamentoCustom[]
  users                  User[]
  configuracoesComissao  ConfiguracaoComissao[]
  clientes               Cliente[]
  fornecedores           Fornecedor[]
  categorias             Categoria[]
  produtos               Produto[]
  vendas                 Venda[]
  vendaPagamentos        VendaPagamento[]
  itensVenda             ItemVenda[]
  compras                Compra[]
  itensCompra            ItemCompra[]
  movimentacoesEstoque   MovimentacaoEstoque[]
  contasPagar            ContaPagar[]
  contasReceber          ContaReceber[]
  anexos                 Anexo[]
  caixas                 Caixa[]
  configuracaoEmpresa    ConfiguracaoEmpresa?
  configuracaoImpressora ConfiguracaoImpressora?
  movimentacoesCaixa     MovimentacaoCaixa[]
  orcamentos             Orcamento[]
  itensOrcamento         ItemOrcamento[]
  configuracaoFidelidade ConfiguracaoFidelidade?
  pontosCliente          PontosCliente[]
  movimentacoesPontos    MovimentacaoPontos[]
  tarefas                Tarefa[]
  interacoes             Interacao[]
  oportunidades          Oportunidade[]
  tags                   Tag[]
  clienteTags            ClienteTag[]
  contatos               Contato[]
  pesquisasNps           PesquisaNps[]
  templatesMensagem      TemplateMensagem[]
  regrasAutomacao        RegraAutomacao[]
  logsAutomacao          LogAutomacao[]
  historicoOportunidades HistoricoOportunidade[]
  logsAuditoria          LogAuditoria[]
  notificacoesRecebidas  Notificacao[]
  inventarios            Inventario[]
  inventarioItens        InventarioItem[]
  intencoesPagamentoMP   IntencaoPagamentoMP[]

  @@map("empresas")
}

// ============ FORMAS DE PAGAMENTO CUSTOM ============

model FormaPagamentoCustom {
  id                 String         @id @default(uuid())
  nome               String
  icone              String?
  baseFormaPagamento FormaPagamento
  ativo              Boolean        @default(true)
  ordem              Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("formas_pagamento_custom")
}

// ============ USUARIOS ============

model User {
  id         String   @id @default(uuid())
  nome       String
  email      String
  senha      String
  role       Role     @default(VENDEDOR)
  ativo      Boolean  @default(true)
  permissoes String[] @default([])
  // superAdmin = desenvolvedor/dono do sistema (cross-tenant). Diferente do
  // role ADMIN que e por tenant. Apenas super-admin pode acessar /admin-master,
  // ver lista de TODAS as empresas e criar novos tenants. Default false: a
  // grande maioria dos users sao admins/gerentes/vendedores de uma empresa.
  superAdmin Boolean  @default(false)
  // Preferencias de UI sincronizadas entre dispositivos. Forma:
  // { aparencia?: {...}, sidebarCollapsed?: boolean }. Mantida como Json
  // intencionalmente flexivel para evoluir sem migration por campo novo.
  preferencias Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendas                   Venda[]
  movimentacoes            MovimentacaoEstoque[]
  caixas                   Caixa[]
  movimentacoesCaixa       MovimentacaoCaixa[]
  orcamentos               Orcamento[]             @relation("OrcamentoCriador")
  orcamentosResponsavel    Orcamento[]             @relation("OrcamentoResponsavel")
  configuracaoComissao     ConfiguracaoComissao?
  interacoes               Interacao[]
  tarefasCriadas           Tarefa[]                @relation("TarefaCriador")
  tarefasResponsavel       Tarefa[]                @relation("TarefaResponsavel")
  movimentacoesPontos      MovimentacaoPontos[]
  oportunidadesCriadas     Oportunidade[]          @relation("OportunidadeCriador")
  oportunidadesResponsavel Oportunidade[]          @relation("OportunidadeResponsavel")
  historicoOportunidades   HistoricoOportunidade[]
  regrasAutomacao          RegraAutomacao[]        @relation("RegraAutomacaoResponsavel")
  logsAuditoria            LogAuditoria[]
  notificacoesCriadas      Notificacao[]           @relation("NotificacaoCriador")
  notificacoesLidas        NotificacaoLida[]
  inventarios              Inventario[]
  intencoesPagamentoMP     IntencaoPagamentoMP[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ============ COMISSAO ============

model ConfiguracaoComissao {
  id           String       @id @default(uuid())
  tipo         TipoComissao @default(PORCENTAGEM)
  base         BaseComissao @default(VALOR_BRUTO)
  valor        Decimal      @db.Decimal(10, 2)
  metaMensal   Decimal      @default(0) @db.Decimal(10, 2)
  bonusPorMeta Decimal      @default(0) @db.Decimal(5, 2)
  ativo        Boolean      @default(true)
  observacoes  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("configuracoes_comissao")
}

// ============ CADASTROS ============

model Cliente {
  id             String             @id @default(uuid())
  nome           String
  cpfCnpj        String?
  email          String?
  telefone       String?
  endereco       String?
  cidade         String?
  estado         String?
  cep            String?
  observacoes    String?
  ativo          Boolean            @default(true)
  origem         String?
  statusFunil    StatusClienteFunil @default(LEAD)
  dataNascimento DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendas              Venda[]
  contasReceber       ContaReceber[]
  orcamentos          Orcamento[]
  interacoes          Interacao[]
  tarefas             Tarefa[]
  pontosCliente       PontosCliente?
  movimentacoesPontos MovimentacaoPontos[]
  oportunidades       Oportunidade[]
  tags                ClienteTag[]
  contatos            Contato[]
  pesquisasNps        PesquisaNps[]

  @@unique([tenantId, cpfCnpj])
  @@index([tenantId])
  @@map("clientes")
}

// Cadastro de Fornecedores preparado para emissao futura de NF-e/NFS-e.
// Os campos fiscais (ie, indIEDest, crt, codigos IBGE) sao opcionais hoje
// mas obedecem a estrutura exigida pela SEFAZ para evitar retrabalho.
model Fornecedor {
  id           String  @id @default(uuid())
  // `nome` = razao social (nome juridico). `nomeFantasia` e o nome de mercado.
  nome         String
  nomeFantasia String?
  // Pessoa fisica ou juridica: "PF" | "PJ". Usado para validar formato do
  // documento (cnpj armazena CPF tambem; nao desdobra em duas colunas).
  tipoPessoa   String?
  cnpj         String?
  email        String?
  telefone     String?

  // --- Endereco segregado (padrao SEFAZ) ---
  // Os antigos `endereco`/`cidade`/`estado` foram mantidos para retrocompat
  // com codigo legado, mas o cadastro novo deve usar os campos segregados.
  endereco         String?
  cidade           String?
  estado           String?
  cep              String?
  numero           String?
  complemento      String?
  bairro           String?
  codMunicipioIBGE String?
  codUFIBGE        String?
  codPais          String  @default("1058")
  nomePais         String  @default("BRASIL")

  // --- Dados fiscais / tributarios ---
  // Inscricao Estadual: aceita string ou null. Se ieIsenta=true, ie deve
  // ser null (validado no controller).
  ie        String?
  ieIsenta  Boolean @default(false)
  // Inscricao Municipal (necessaria para servicos / NFS-e).
  im        String?
  // Indicador de IE do destinatario (campo indIEDest da NF-e):
  // 1 = Contribuinte ICMS, 2 = Isento, 9 = Nao contribuinte.
  indIEDest Int?
  // Codigo de Regime Tributario (CRT):
  // 1 = Simples Nacional, 2 = Simples Nacional/Excesso, 3 = Regime Normal.
  crt       Int?

  // E-mail dedicado para recebimento de XML/DANFE da NF-e.
  emailNFe String?

  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  produtos    Produto[]
  compras     Compra[]
  contasPagar ContaPagar[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@map("fornecedores")
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String
  createdAt DateTime @default(now())

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  produtos Produto[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("categorias")
}

// ============ PRODUTOS / ESTOQUE ============

model Produto {
  id            String   @id @default(uuid())
  codigo        String
  codigoBarras  String?
  referencia    String?
  nome          String
  descricao     String?
  imagem        String?
  tipoItem      TipoItem @default(PRODUTO)
  precoVenda    Decimal  @db.Decimal(10, 2)
  precoCusto    Decimal? @db.Decimal(10, 2)
  // Estoque com 3 casas decimais — suporta unidades fracionarias (M, KG, L)
  // alem de UN inteira. Quem vende por metro decrementa 1.5; quem vende UN
  // continua usando inteiros naturalmente (1.000, 2.000 etc).
  estoque       Decimal  @default(0) @db.Decimal(12, 3)
  estoqueMinimo Decimal  @default(0) @db.Decimal(12, 3)
  unidade       String   @default("UN")
  ativo         Boolean  @default(true)

  // ============ ETAPA 14: BLOCO FISCAL (NF-e / NFC-e) ============
  //
  // Todos os campos sao opcionais no cadastro — viram obrigatorios na
  // emissao da nota fiscal (validado no controller de NF-e na etapa 15).
  // A regra agora e: se o cliente preencher, tem que estar bem-formado.

  // NCM (Nomenclatura Comum do Mercosul) — 8 digitos. Obrigatorio em
  // 100% das NF-e (rejeicao 778 se vazio/invalido). Tem que constar na
  // TIPI; aqui validamos so formato.
  ncm String? @db.VarChar(8)

  // CEST (Codigo Especificador da Substituicao Tributaria) — 7 digitos.
  // Condicionalmente obrigatorio (so para itens com ST, Conv. 92/2015).
  cest String? @db.VarChar(7)

  // CFOP padrao de saida (4 digitos, comeca com 5/6/7). Default usado
  // ao emitir nota; pode ser sobrescrito por operacao (interestadual
  // muda 5xxx -> 6xxx).
  cfopPadrao String? @db.VarChar(4)

  // Origem (Tabela A) — sempre presente no XML. Default NACIONAL cobre
  // ~95% dos casos em papelaria/comercio brasileiro.
  origem OrigemMercadoria @default(NACIONAL)

  // Unidade tributavel — pode diferir da comercial (ex: vende em CX,
  // tributa em UN). Vazio = usa o campo `unidade` na emissao.
  unidadeTributavel String? @db.VarChar(6)

  // Regime do item — define qual dos dois campos (cstIcms/csosnIcms)
  // sera populado no XML. Default SIMPLES_NACIONAL = cenario mais comum.
  regimeTributario RegimeTributario @default(SIMPLES_NACIONAL)

  // CST do ICMS — 3 digitos (Tabela B SEFAZ). So em REGIME_NORMAL.
  // Exemplos: "000" tributada integral, "020" com red. BC, "040" isenta,
  // "060" ICMS ja retido por ST, "090" outras.
  cstIcms String? @db.VarChar(3)

  // CSOSN — 4 digitos (Tabela B Simples). So em SIMPLES_*.
  // Exemplos: "101" com permissao de credito, "102" sem permissao,
  // "500" ICMS cobrado por ST, "900" outras.
  csosnIcms String? @db.VarChar(4)

  // Aliquota efetiva do ICMS (%). No Simples costuma ficar zerada
  // (recolhido no DAS); em regime normal varia 7-25% por UF/produto.
  aliquotaIcms Decimal? @db.Decimal(5, 2)

  // PIS / COFINS — CST de 2 digitos + aliquota. Obrigatorios em toda
  // NF-e modelo 55 e NFC-e modelo 65. Em Simples geralmente "49"
  // (outras operacoes de saida) com aliquota 0.
  cstPis         String?  @db.VarChar(2)
  aliquotaPis    Decimal? @db.Decimal(7, 4)
  cstCofins      String?  @db.VarChar(2)
  aliquotaCofins Decimal? @db.Decimal(7, 4)

  // cBenef — Codigo de Beneficio Fiscal (ate 10 chars). Obrigatorio
  // quando o produto goza de algum beneficio (red. BC, diferimento,
  // isencao especifica). Cada UF publica sua tabela.
  codBeneficioFiscal String? @db.VarChar(10)

  // Pesos em kg (3 casas). Nao obrigatorios na NF-e, mas SEFAZ
  // recomenda — usados em notas de transporte e auditoria fiscal.
  pesoLiquido Decimal? @db.Decimal(10, 3)
  pesoBruto   Decimal? @db.Decimal(10, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itensVenda      ItemVenda[]
  itensCompra     ItemCompra[]
  itensOrcamento  ItemOrcamento[]
  movimentacoes   MovimentacaoEstoque[]
  inventarioItens InventarioItem[]

  @@unique([tenantId, codigo])
  @@unique([tenantId, codigoBarras])
  @@index([tenantId])
  @@map("produtos")
}

// ============ VENDAS (PDV) ============

model Venda {
  id             String         @id @default(uuid())
  // Numero sequencial POR TENANT. Calculado no controller via MAX+1
  // com retry em caso de race condition (ver lib/proximoNumero.js).
  numero         Int
  total          Decimal        @db.Decimal(10, 2)
  desconto       Decimal        @default(0) @db.Decimal(10, 2)
  formaPagamento FormaPagamento
  status         StatusVenda    @default(CONCLUIDA)
  observacoes    String?
  createdAt      DateTime       @default(now())

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  caixaId String?
  caixa   Caixa?  @relation(fields: [caixaId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itens               ItemVenda[]
  pagamentos          VendaPagamento[]
  movimentacoesCaixa  MovimentacaoCaixa[]
  orcamento           Orcamento?
  contasReceber       ContaReceber[]
  movimentacoesPontos MovimentacaoPontos[]
  oportunidade        Oportunidade?
  pesquisaNps         PesquisaNps?

  @@unique([tenantId, numero])
  @@index([caixaId])
  @@index([tenantId])
  @@map("vendas")
}

// Split de pagamento: cada Venda pode ter 1..N pagamentos (DINHEIRO + PIX +
// CARTAO, etc.). A soma dos valores == Venda.total (excedente em DINHEIRO
// vira troco e nao entra como pagamento). Venda.formaPagamento (legado)
// continua existindo e refletindo a forma de MAIOR valor para manter
// filtros/relatorios existentes funcionando sem reescrita.
model VendaPagamento {
  id              String         @id @default(uuid())
  forma           FormaPagamento
  valor           Decimal        @db.Decimal(10, 2)
  // Snapshot textual da forma personalizada (ex: "Cartao Banco do Brasil").
  // Sem FK pra FormaPagamentoCustom — preserva nome historico se a custom
  // for desativada/renomeada depois.
  formaCustomNome String?
  ordem           Int            @default(0)
  createdAt       DateTime       @default(now())

  vendaId String
  venda   Venda  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([vendaId])
  @@index([tenantId])
  @@map("venda_pagamentos")
}

model ItemVenda {
  id            String  @id @default(uuid())
  // Quantidade fracionaria (ate 3 casas) — produtos vendidos por metro,
  // quilo ou litro usam decimais; produtos em UN seguem inteiros.
  quantidade    Decimal @db.Decimal(12, 3)
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  vendaId String
  venda   Venda  @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("itens_venda")
}

// ============ COMPRAS ============

model Compra {
