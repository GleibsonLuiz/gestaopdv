{
  "name": "gestao-pdv-backend",
  "version": "1.0.0",
  "description": "Backend do sistema de Gestao + PDV",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.js",
    "dev:node": "nodemon src/server.js",
    "prestart": "prisma generate",
    "start": "tsx src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"src/**/*.test.js\"",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "db:backup": "node scripts/db-manager.js backup",
    "db:restore": "node scripts/db-manager.js restore",
    "db:list": "node scripts/db-manager.js list",
    "db:verify": "node scripts/db-manager.js verify"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
