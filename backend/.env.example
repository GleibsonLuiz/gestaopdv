# Porta do servidor
PORT=3333

# Banco de dados PostgreSQL (Neon, Railway ou local)
DATABASE_URL="postgresql://usuario:senha@host:5432/nome_banco?schema=public"

# Chave secreta JWT (gere uma string aleatoria longa para producao)
JWT_SECRET="troque-esta-chave-por-uma-aleatoria-bem-grande"
JWT_EXPIRES_IN="7d"

# Chave de autenticacao do cron (Vercel Cron / scheduler externo)
# Vercel Cron envia automaticamente o header Authorization: Bearer ${CRON_SECRET}.
# Define em "Settings > Environment Variables" no projeto Vercel.
# Gere uma string aleatoria com: openssl rand -hex 32
# Endpoints protegidos por essa chave: GET/POST /cron/automacoes,
# GET/POST /cron/assinaturas (reconciliacao do billing).
CRON_SECRET=""

# ============ MODULO ASSINATURA (billing / cobranca recorrente do SaaS) ============
# Gateway que cobra a MENSALIDADE de cada empresa-cliente. NAO confundir com o
# Mercado Pago Point (maquininha das vendas do lojista) — sao fluxos distintos.
#
# Provedor ativo: "mock" (default — ativa na hora, sem cobranca real, p/ dev/demo)
# ou "asaas" (cobranca real via PIX/boleto/cartao). Em producao use asaas.
BILLING_PROVEDOR="mock"
#
# SEGURANCA: com o mock, o botao "Assinar" do cliente ativaria o plano DE GRACA.
# Por isso a contratacao self-service fica BLOQUEADA quando o provedor e mock.
# Para testar o fluxo mock em dev/homolog, libere explicitamente:
BILLING_PERMITIR_MOCK="false"
#
# Credenciais Asaas (so necessarias quando BILLING_PROVEDOR=asaas):
#   ASAAS_API_KEY       - chave de API da sua conta Asaas (header access_token)
#   ASAAS_AMBIENTE      - "sandbox" (testes) ou "producao"
#   ASAAS_WEBHOOK_TOKEN - token que voce define no painel do Asaas em
#                         "Integracoes > Webhooks" e que validamos no header
#                         asaas-access-token de cada webhook (URL do webhook:
#                         https://SEU-BACKEND/webhooks/billing).
ASAAS_API_KEY=""
ASAAS_AMBIENTE="sandbox"
ASAAS_WEBHOOK_TOKEN=""

# Chave AES-256 para cifrar credenciais sensiveis de integracoes (ex:
# ACCESS_TOKEN do Mercado Pago Point). DEVE ter 32 bytes em hex
# (exatamente 64 caracteres hexadecimais). Sem essa variavel, qualquer
# tentativa de salvar ou usar config da maquininha MP retorna erro.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: NUNCA trocar esta chave depois de ter dados cifrados no banco
# — os tokens guardados ficariam ilegiveis. Em prod, guarde em Secrets Manager.
CRIPTO_SECRET=""

# ============ ETAPA#9b: ATENDIMENTO INTELIGENTE WHATSAPP + IA ============
# Chave da API Anthropic (Claude) usada para gerar respostas automaticas
# do atendimento via WhatsApp. Obtenha em https://console.anthropic.com
# Modelo default e claude-haiku-4-5; pode trocar via ANTHROPIC_MODEL.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5"

# URL base do gateway externo de WhatsApp (Evolution API ou similar).
# Default e https://evolution.api (placeholder). Em prod aponte para
# sua instancia hospedada (ex: https://evo.minha-empresa.com).
EVOLUTION_BASE_URL="https://evolution.api"

