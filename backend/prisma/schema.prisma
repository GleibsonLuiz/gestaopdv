// ============ FINANCEIRO ============

model MovimentacaoEstoque {
  id            String           @id @default(uuid())
  tipo          TipoMovimentacao
  // 3 casas decimais para acompanhar Produto.estoque. Auditoria preserva o
  // valor exato movimentado (ex: SAIDA 1.5m de tecido) sem arredondar.
  quantidade    Decimal          @db.Decimal(12, 3)
  estoqueAntes  Decimal          @db.Decimal(12, 3)
  estoqueDepois Decimal          @db.Decimal(12, 3)
  motivo        String?
  createdAt     DateTime         @default(now())

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([produtoId, createdAt])
  @@index([tenantId])
  @@map("movimentacoes_estoque")
}

// ============ INVENTARIO (CONTAGEM CEGA) ============
//
// Modulo de auditoria fisica de estoque. O fluxo "cego" significa que o
// operador que conta NAO ve o estoqueLogico do sistema — assim a contagem
// nao e enviesada. O snapshot e tirado no momento da abertura (Inventario
// ABERTO) e a consolidacao gera AJUSTE em MovimentacaoEstoque dentro de
// uma transacao Prisma (atomico — ou tudo, ou nada).

model Inventario {
  id              String           @id @default(uuid())
  // Numero sequencial POR TENANT. Calculado no controller via MAX+1.
  numero          Int
  descricao       String?
  observacoes     String?
  // Snapshot do filtro aplicado na abertura (categoria/localizacao). Mantido
  // como referencia textual para o relatorio; o filtro real ja foi aplicado
  // ao gerar os itens em InventarioItem.
  filtroCategoria String?
  status          StatusInventario @default(ABERTO)
  dataInicio      DateTime         @default(now())
  dataFim         DateTime?

  // Responsavel pela abertura (gestor). Operador da contagem nao precisa
  // ser User — pode ser anotado em `observacoes` ou em campo livre no item.
  responsavelId String
  responsavel   User   @relation(fields: [responsavelId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itens InventarioItem[]

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@map("inventarios")
}

model InventarioItem {
  id String @id @default(uuid())

  // Snapshot CONGELADO do estoque do sistema no momento da abertura.
  // NUNCA atualizado depois — e a "verdade do sistema" naquele instante,
  // contra a qual a contagem fisica sera confrontada.
  estoqueLogico Decimal @db.Decimal(12, 3)
  // Snapshot tambem do precoCusto, pra calcular impacto financeiro mesmo
  // que o produto mude de preco depois.
  precoCustoMomento Decimal? @db.Decimal(10, 2)
  // Quantidade contada fisicamente. Null = ainda nao contado.
  // O frontend NUNCA exibe estoqueLogico ao operador da contagem.
  quantidadeContada Decimal? @db.Decimal(12, 3)
  // Diferenca = contada - logico. Pode ser negativo (falta) ou positivo
  // (sobra). Calculado pelo controller a cada salvamento de contagem.
  diferenca Decimal? @default(0) @db.Decimal(12, 3)
  observacao String?
  contadoEm  DateTime?

  inventarioId String
  inventario   Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)

  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([inventarioId, produtoId])
  @@index([tenantId])
  @@index([inventarioId])
  @@map("inventario_itens")
}

model ContaPagar {
  id                 String          @id @default(uuid())
  descricao          String
  valor              Decimal         @db.Decimal(10, 2)
  valorBruto         Decimal         @default(0) @db.Decimal(10, 2)
  juros              Decimal         @default(0) @db.Decimal(10, 2)
  multa              Decimal         @default(0) @db.Decimal(10, 2)
  desconto           Decimal         @default(0) @db.Decimal(10, 2)
  vencimento         DateTime
  pagamento          DateTime?
  status             StatusConta     @default(PENDENTE)
  observacoes        String?
  tipoRecorrencia    TipoRecorrencia @default(NENHUMA)
  grupoRecorrenciaId String?
  parcelaAtual       Int?
  parcelaTotal       Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])

  compraId String?
  compra   Compra? @relation(fields: [compraId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  anexos             Anexo[]
  movimentacoesCaixa MovimentacaoCaixa[]

  @@index([grupoRecorrenciaId])
  @@index([compraId])
  @@index([tenantId])
  @@map("contas_pagar")
}

model ContaReceber {
  id                 String          @id @default(uuid())
  descricao          String
  valor              Decimal         @db.Decimal(10, 2)
  valorBruto         Decimal         @default(0) @db.Decimal(10, 2)
  juros              Decimal         @default(0) @db.Decimal(10, 2)
  multa              Decimal         @default(0) @db.Decimal(10, 2)
  desconto           Decimal         @default(0) @db.Decimal(10, 2)
  vencimento         DateTime
  recebimento        DateTime?
  status             StatusConta     @default(PENDENTE)
  observacoes        String?
  tipoRecorrencia    TipoRecorrencia @default(NENHUMA)
  grupoRecorrenciaId String?
  parcelaAtual       Int?
  parcelaTotal       Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  vendaId String?
  venda   Venda?  @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Empresa @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  anexos             Anexo[]
  movimentacoesCaixa MovimentacaoCaixa[]

